{
  "name": "fuelle-mobile",
  "version": "0.5.0",
  "description": "Fuelle nutrition tracker — mobile build",
  "private": true,
  "scripts": {
    "sync:ios":     "npx cap sync ios",
    "sync:android": "npx cap sync android",
    "open:ios":     "npx cap open ios",
    "open:android": "npx cap open android",
    "build:android": "npx cap sync android && cd android && ./gradlew assembleRelease",
    "build:ios":     "npx cap sync ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Release -archivePath build/fuelle.xcarchive archive"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
